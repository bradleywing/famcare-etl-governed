# ============================================================
.Rhistory
.Rapp.history
.RData
.RDataTmp
.Ruserdata
.Rproj.user/
.Renviron

# R CMD build/check outputs
/*.tar.gz
/*.Rcheck/

# Example code in package build process
*-Ex.R

# R Markdown / Bookdown
_bookdown_files/
_book/

# knitr and R markdown default cache directories
*_cache/
/cache/

# Temporary files created by R markdown
*.utf8.md
*.knit.md

# produced vignettes
vignettes/*.html
vignettes/*.pdf

# OAuth2 token
.httr-oauth

